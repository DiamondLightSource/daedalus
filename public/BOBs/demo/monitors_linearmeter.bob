<display version="2.0.0">
  <name>Meter Widgets</name>
  <width>980</width>
  <height>1000</height>
  <widget type="label" version="2.0.0">
    <name>Label</name>
    <class>TITLE</class>
    <text>Linear Meter Widgets</text>
    <x use_class="true">0</x>
    <y use_class="true">0</y>
    <width>550</width>
    <height>31</height>
    <font use_class="true">
      <font name="Header 1" family="Liberation Sans" style="BOLD" size="22.0">
      </font>
    </font>
    <foreground_color use_class="true">
      <color name="Text" red="0" green="0" blue="0">
      </color>
    </foreground_color>
    <transparent use_class="true">true</transparent>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_1</name>
    <text>Meters display numerical values.
By default, the meter reflects the range, units, alarm limits, and current alarm state of the process variable.</text>
    <y>31</y>
    <width>370</width>
    <height>70</height>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Label_2</name>
    <text>Alarm limits form widget config</text>
    <x>20</x>
    <y>250</y>
    <width>370</width>
    <height>39</height>
  </widget>
  <widget type="linearmeter" version="2.0.0">
    <name>LinearMeter</name>
    <pv_name>sim://sine(10,50,0.5)</pv_name>
    <x>10</x>
    <y>120</y>
    <width>400</width>
    <height>105</height>
    <colors>
      <foreground_color>
        <color name="Text" red="0" green="0" blue="0">
        </color>
      </foreground_color>
      <background_color>
        <color red="0" green="0" blue="0" alpha="0">
        </color>
      </background_color>
      <needle_color>
        <color red="0" green="0" blue="0">
        </color>
      </needle_color>
      <knob_color>
        <color red="0" green="0" blue="0">
        </color>
      </knob_color>
      <normal_status_color>
        <color red="194" green="198" blue="195">
        </color>
      </normal_status_color>
      <minor_warning_color>
        <color red="242" green="148" blue="141">
        </color>
      </minor_warning_color>
      <major_warning_color>
        <color red="240" green="60" blue="46">
        </color>
      </major_warning_color>
      <is_gradient_enabled>false</is_gradient_enabled>
      <is_highlighting_of_active_regions_enabled>false</is_highlighting_of_active_regions_enabled>
    </colors>
    <minimum>10.0</minimum>
    <maximum>50.0</maximum>
    <level_lolo>15.0</level_lolo>
    <level_low>25.0</level_low>
    <level_high>35.0</level_high>
    <level_hihi>45.0</level_hihi>
  </widget>
