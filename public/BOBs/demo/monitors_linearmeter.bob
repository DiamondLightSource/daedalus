        </color>
      </knob_color>
      <normal_status_color>
        <color name="OK" red="0" green="255" blue="0">
        </color>
      </normal_status_color>
      <minor_warning_color>
        <color name="Attention" red="255" green="160" blue="0">
        </color>
      </minor_warning_color>
      <major_warning_color>
        <color name="INVALID" red="255" green="0" blue="255">
        </color>
