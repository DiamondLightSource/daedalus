  <widget type="linearmeter" version="2.0.0">
    <name>LinearMeter_3</name>
    <pv_name>sim://sine(10,50,0.5)</pv_name>
    <x>220</x>
    <y>459</y>
    <width>105</width>
    <height>400</height>
    <show_units>false</show_units>
    <scale_visible>false</scale_visible>
    <displayHorizontal>false</displayHorizontal>
    <knob_size>30</knob_size>
